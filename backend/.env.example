# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# JWT — Generar un secreto único con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_hex_string_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────────
# Base de datos MySQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=nexapanel_db

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Proveedor SMM
# ─────────────────────────────────────────────
SMM_PROVIDER_URL=https://your-provider.com/api/v2
SMM_PROVIDER_KEY=change_me

# ─────────────────────────────────────────────
# Email (Nodemailer)
# ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu@email.com
MAIL_PASS=tu_app_password
MAIL_FROM=NexaPanel <noreply@nexapanel.io>

# ─────────────────────────────────────────────
# Pagos (opcional)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_change_me
PAYPAL_CLIENT_ID=change_me
PAYPAL_CLIENT_SECRET=change_me
